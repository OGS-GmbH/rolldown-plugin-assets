{
  "name": "@ogs-gmbh/rolldown-plugin-assets",
  "version": "1.0.0",
  "description": "A Rolldown plugin that emits static assets (files and directories) to the output directory during the build process.",
  "keywords": [
    "assets",
    "build",
    "bundler",
    "plugin",
    "rolldown",
    "rolldown-plugin",
    "static-assets"
  ],
  "homepage": "https://ogs-gmbh.github.io/rolldown-plugin-assets",
  "bugs": "https://github.com/OGS-GmbH/rolldown-plugin-assets/issues",
  "license": "MIT",
  "author": "OGS GmbH",
  "contributors": [
    {
      "name": "Simon Kovtyk",
      "email": "simon@kovtyk.com",
      "url": "https://simonkov.dev"
    }
  ],
  "repository": "https://github.com/OGS-GmbH/rolldown-plugin-assets",
  "files": [
    "./dist/main",
    "CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/main/public-api.d.ts",
    "default": "./dist/main/public-api.js"
  },
  "scripts": {
    "ci:build:main:production": "tsdown",
    "ci:docs:extract:typedoc": "typedoc",
    "ci:docs:main:vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress build .vitepress",
    "ci:pr:commitlint:main:commitlint": "commitlint",
    "ci:pr:lint:main:oxfmt": "oxfmt --check",
    "ci:pr:lint:main:oxlint": "oxlint",
    "commit": "commit",
    "prepare": "husky",
    "vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress dev .vitepress",
    "vitepress:preview": "vitepress preview .vitepress"
  },
  "dependencies": {
    "rolldown": "1.0.0-rc.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@ogs-gmbh/oxlint-presets": "^1.0.5",
    "@ogs-gmbh/vitepress-plugin-sidebar": "^1.0.3",
    "@ogs-gmbh/vitepress-theme": "^1.1.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "sass-embedded": "^1.98.0",
    "tsdown": "^0.21.7",
    "typedoc": "^0.28.18",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.3"
  }
}
